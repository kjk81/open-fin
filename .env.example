# ─── Alpaca ──────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Worker-specific Alpaca credentials (falls back to ALPACA_API_KEY/SECRET)
# ALPACA_WORKER_API_KEY=
# ALPACA_WORKER_API_SECRET=

# ─── LLM providers (set any you plan to use) ────────────────────────────────
OLLAMA_MODEL=qwen3:4b-instruct
# OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
HF_API_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ─── Data Sources ────────────────────────────────────────────────────────────
# FMP_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=

# ─── Anomaly Worker ─────────────────────────────────────────────────────────
# ANOMALY_INTERVAL_MINUTES=5
# ANOMALY_PRICE_DROP=0.05
# ANOMALY_VOLUME_SPIKE=2.0
# ANOMALY_GAP_DOWN=0.03

# ─── Internal Paths (set by Electron — override only for manual runs) ───────
# OPEN_FIN_DB_PATH=
# OPEN_FIN_KG_PATH=
# OPEN_FIN_ENV_PATH=
# OPEN_FIN_FAISS_DIR=
