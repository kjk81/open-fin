# ─── Alpaca (Phase 1) ───────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Worker-specific Alpaca credentials (falls back to ALPACA_API_KEY/SECRET)
# ALPACA_WORKER_API_KEY=
# ALPACA_WORKER_API_SECRET=

# ─── LLM Provider (Phase 2) ─────────────────────────────────────────────────
# Set exactly ONE of the groups below. Priority order: Ollama → OpenRouter →
# OpenAI → Groq → Gemini → HuggingFace.

# Option 1: Ollama (local, free — requires Ollama running on localhost:11434)
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# Option 2: OpenRouter (recommended online default)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct   # optional, has default
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Option 3: OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini   # optional, has default
# OPENAI_BASE_URL=              # optional, for compatible proxies

# Option 4: Groq (fast inference, generous free tier)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama3-8b-8192   # optional, has default
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Option 5: Google Gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash   # optional, has default

# Option 6: HuggingFace Inference API
# HF_API_TOKEN=hf_...
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2   # optional, has default
# HF_BASE_URL=                  # optional, custom HF endpoint

# ─── Data Sources ────────────────────────────────────────────────────────────
# FMP (Financial Modeling Prep) for financial statements, filings, etc.
# FMP_API_KEY=

# Twelve Data (free-tier quote/time-series fallback)
# TWELVE_DATA_API_KEY=

# Finnhub (free-tier market/fundamentals/news fallback)
# FINNHUB_API_KEY=

# Alpha Vantage (free-tier quote/fundamental fallback)
# ALPHA_VANTAGE_API_KEY=

# Tiingo (free-tier daily pricing fallback)
# TIINGO_API_KEY=

# EOD Historical Data (free-tier historical + fundamentals fallback)
# EODHD_API_TOKEN=

# Tavily search API for web research
# TAVILY_API_KEY=

# Exa search API (alternative to Tavily)
# EXA_API_KEY=

# ─── Anomaly Worker ─────────────────────────────────────────────────────────
# ANOMALY_INTERVAL_MINUTES=5
# ANOMALY_PRICE_DROP=0.05
# ANOMALY_VOLUME_SPIKE=2.0
# ANOMALY_GAP_DOWN=0.03

# ─── Internal Paths (set by Electron — override only for manual runs) ───────
# OPEN_FIN_DB_PATH=             # SQLite database file path
# OPEN_FIN_KG_PATH=             # Knowledge Graph JSON path (legacy)
# OPEN_FIN_ENV_PATH=            # Path to .env file (this file)
# OPEN_FIN_FAISS_DIR=           # FAISS vector index directory
